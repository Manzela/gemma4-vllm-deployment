# Gemma 4 vLLM Deployment — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp deploy_config.env.example .env

# ────────────────────────────────────────
# Required Configuration
# ────────────────────────────────────────

# Your HuggingFace token (required for gated model access)
HF_TOKEN=hf_your_token_here

# Your GCP project ID
GCP_PROJECT=your-project-id

# Deployment region (must have A100 80GB quota)
GCP_REGION=us-central1

# Full URI to your GCSFUSE container in Artifact Registry
IMAGE_URI=us-central1-docker.pkg.dev/your-project/your-repo/gcsfuse-vllm-gemma4:latest

# Vertex AI endpoint ID (create one first if you don't have it)
SLM_ENDPOINT_ID=your_endpoint_id

# ────────────────────────────────────────
# Deployment Mode
# ────────────────────────────────────────

# Enable LoRA adapter loading (currently blocked — see KNOWN_LIMITATIONS.md)
# Options: true, false
SLM_ENABLE_LORA=false

# Quantization method (⚠️ "bitsandbytes" is broken for MoE — see FORENSIC_RUNBOOK.md)
# Options: none, bitsandbytes, awq, gptq
SLM_QUANTIZATION=none

# Model version label (for display name and traceability)
SLM_MODEL_VERSION=v1

# Use GCSFUSE container (always recommended)
SLM_USE_GCSFUSE=true

# ────────────────────────────────────────
# Optional: LoRA Adapter Bucket
# ────────────────────────────────────────

# GCS bucket for LoRA adapters (mounted at /mnt/gcs/ by GCSFUSE)
LORA_ADAPTER_BUCKET=your-lora-adapters-bucket
